# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# CMS database (production data lives on server)
/data/cms.sqlite
/data/cms.sqlite-*

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# Google Search Console service account keys (see docs/GSC_API_CLOSED_LOOP.md)
/secrets/
gsc-service-account*.json
data/gsc-oauth-tokens.json
secrets/gsc-oauth-production.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# cron logs (paths under logs/ are created on server)
/logs/*.log
